# Database
POSTGRES_USER=conversation_stats
POSTGRES_PASSWORD=conversation_stats
POSTGRES_DB=conversation_stats
DATABASE_URL=postgresql+psycopg://conversation_stats:conversation_stats@db:5432/conversation_stats

# App role: api | scheduler
APP_ROLE=api

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/2
REDIS_PUBSUB_URL=redis://redis:6379/3
CACHE_TTL_SECONDS=10800
CACHE_ENABLED=true
RESPONSE_SLA_SECONDS=60

# Scheduler (DISABLED by default — the pipeline now runs on request only via
# POST /api/pipeline/run. These vars are only used if you re-enable the
# `scheduler` service in docker-compose.yml.)
PIPELINE_CRON=0 */2 * * *
PIPELINE_INTERVAL_SECONDS=7200
SCHEDULED_AGENT_IDS=

# Hugging Face model cache (persisted via Docker volume on scheduler)
HF_HOME=/app/.cache/huggingface
TRANSFORMERS_CACHE=/app/.cache/huggingface/hub

# Backend
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
PRELOAD_MODELS=true

# Sentiment
SENTIMENT_MODEL=tabularisai/multilingual-sentiment-analysis
SENTIMENT_CONFIDENCE_THRESHOLD=0.55

# Embeddings / intents / unanswered
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
INTENT_MODEL=MoritzLaurer/mDeBERTa-v3-base-xnli-multilingual-nli-2mil7
# Intent/NLI inference: local (CPU) | hf_api (Serverless) | hf_endpoint (dedicated GPU URL)
INTENT_INFERENCE_MODE=hf_api
HF_TOKEN=
# Required when INTENT_INFERENCE_MODE=hf_endpoint (production GPU server)
INTENT_INFERENCE_ENDPOINT=
QUESTION_CLUSTER_DISTANCE=0.25
INTENT_LABELS=refund,shipping,order_status,account,pricing,product_info,complaint,technical_support,general
INTENT_CONFIDENCE_THRESHOLD=0.35
INTENT_COMPLAINT_MIN_SCORE=0.45
INTENT_SUPPORTED_LANGUAGES=nl,en,de,fr,es
# Optional override; leave empty to use per-language defaults
INTENT_HYPOTHESIS_TEMPLATE=
UNANSWERED_SIMILARITY_THRESHOLD=0.45
UNANSWERED_NLI_THRESHOLD=0.55
UNANSWERED_NLI_LABELS=answers the question,partially answers,does not answer,deflects

# Momants API
MOMANTS_API_BASE_URL=https://your-momants-host
MOMANTS_DEV_IDENTIFIER=
MOMANTS_DEV_PASSWORD=
MOMANTS_API_KEY=
MOMANTS_API_CONNECT_TIMEOUT_SECONDS=30
MOMANTS_API_READ_TIMEOUT_SECONDS=120
MOMANTS_API_MAX_RETRIES=3
MOMANTS_API_RETRY_BACKOFF_SECONDS=2
INGESTION_MAX_CONVERSATIONS=5000
INGESTION_BATCH_SIZE=100
PIPELINE_INSIGHTS_PER_BATCH=true
MAX_CONCURRENT_JOBS=10
MAX_CONCURRENT_INGEST=10
MAX_CONCURRENT_INSIGHTS=2
# Per-agent fairness so one agent can't grab every global slot (effective = min(global, per-agent)).
MAX_CONCURRENT_INGEST_PER_AGENT=8
MAX_CONCURRENT_INSIGHTS_PER_AGENT=4
INTENT_BATCH_SIZE=8
# The Momants API caps results at 50/page but computes total_pages from the requested size.
# Requesting >50 makes it report half the pages, so pagination stops at half the data. Keep 50.
INGESTION_PAGE_SIZE=50
# Date-range ingestion so all conversations can be fetched, not just the first N pages.
# Use small windows (1 day) to stay under the API's 50-per-page cap on busy days.
INGESTION_USE_DATE_WINDOWS=true
INGESTION_WINDOW_DAYS=1
INGESTION_MAX_EMPTY_WINDOWS=4
# Client-side cap on Momants API requests/second (shared across all ingest threads).
MOMANTS_API_MAX_REQUESTS_PER_SECOND=5
# SQLAlchemy connection pool. Keep >= per-process concurrent sessions
# (per-agent ingest workers + insights + main + cache warming).
DB_POOL_SIZE=15
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30

# Slack notifications for on-request rapport runs.
# Bot token (xoxb-...) with scopes: users:read.email, chat:write, im:write.
# Leave empty to disable Slack DMs entirely.
SLACK_BOT_TOKEN=
SLACK_TIMEOUT_SECONDS=10
# Public base URL of the rapport dashboard, used to build the "PDF ready" link.
APP_BASE_URL=http://localhost:5173

# Frontend (build-time; leave empty to use same-origin /api proxy)
VITE_API_BASE_URL=

# Google OAuth (internal access)
AUTH_REQUIRED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/oauth/callback
AUTH_SECRET=change-me-in-production
AUTH_ALLOWED_EMAIL_DOMAINS=momants.ai
AUTH_TOKEN_TTL_SECONDS=604800
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
